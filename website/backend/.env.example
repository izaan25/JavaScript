# Server port
PORT=5000

# Set to production when deploying
NODE_ENV=development

# ─── Python Data Folder Path ────────────────────────────────────────────────────────
# The server reads from the data folder containing code and documentation
# If the data folder is in a different location, set the full absolute path here:
#
# Windows example:
# PYTHON_PATH=C:\Users\HP\OneDrive\Documents\Python\data
#
# Mac/Linux example:
# PYTHON_PATH=/Users/yourname/Documents/Python/data
#
# Default behavior: Looks for data folder relative to backend directory
# (../../../data from website/backend/)

# ─── Optional Settings ───────────────────────────────────────────────────────────
# Maximum scan depth for directory traversal
MAX_SCAN_DEPTH=3

# File types to include (comma-separated)
INCLUDE_FILE_TYPES=.py,.md,.txt,.js,.html,.css

# Directories to exclude (comma-separated)
EXCLUDE_DIRS=node_modules,venv,__pycache__,.git

# Enable detailed logging (true/false)
VERBOSE_LOGGING=false
